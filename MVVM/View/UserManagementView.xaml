<?xml version="1.0" encoding="utf-8" ?>
    
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DecadePerfume.MVVM.View.UserManagementView">

    <StackLayout Padding="20">

        <Label Text="User Management" TextColor="#F7D060"/>

        <Entry x:Name="UsernameEntry" Placeholder="Username"/>
        <Entry x:Name="PasswordEntry" Placeholder="Password"/>
        <Picker x:Name="RolePicker" Title="Select Role">
            <Picker.Items>
                <x:String>admin</x:String>
                <x:String>user</x:String>
            </Picker.Items>
        </Picker>

        <!--<Button Text="Add User" Clicked="AddUser_Clicked"/>-->
        <Button Text="Edit User"/>
        <Button Text="Delete User"/>

    </StackLayout>
    
</ContentPage>