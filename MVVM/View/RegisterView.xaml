<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DecadePerfume.MVVM.View.RegisterView"
             BackgroundColor="#D4AF37"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="220,*">

        <!-- Top Logo Section -->
        <Grid Grid.Row="0"
              BackgroundColor="#D4AF37">
            <Frame WidthRequest="160"
                   HeightRequest="160"
                   CornerRadius="80"
                   BackgroundColor="Black"
                   Padding="15"
                   HasShadow="False"
                   BorderColor="Transparent"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="0,100,0,0">
                <Image Source="decadelogo.png"
                       Aspect="AspectFit"/>
            </Frame>
        </Grid>

        <!-- Form Section -->
        <Frame Grid.Row="1"
               BackgroundColor="#0D0D0D"
               CornerRadius="0"
               Padding="25,30,25,20"
               HasShadow="False"
               BorderColor="Transparent"
               VerticalOptions="FillAndExpand">

            <StackLayout Spacing="8">

                <Label Text="Sign in with"
                       FontSize="20"
                       TextColor="#F7D060"
                       HorizontalTextAlignment="Center"/>

                <Label Text="Decade Perfume"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#F7D060"
                       HorizontalTextAlignment="Center"/>

                <!-- Email -->
                <Border Stroke="#F7D060"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="15,2">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="15">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="&#xe804;"
                                                 FontFamily="Fontello"
                                                 Color="#F7D060"
                                                 Size="20"/>
                            </Image.Source>
                        </Image>
                        <Entry x:Name="EmailEntry"
                               Grid.Column="1"
                               Placeholder="Email Address"
                               PlaceholderColor="#807040"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Username -->
                <Border Stroke="#F7D060"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="15,2">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="15">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="&#xe802;"
                                                 FontFamily="Fontello"
                                                 Color="#F7D060"
                                                 Size="20"/>
                            </Image.Source>
                        </Image>
                        <Entry x:Name="UsernameEntry"
                               Grid.Column="1"
                               Placeholder="Username"
                               PlaceholderColor="#807040"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Contact -->
                <Border Stroke="#F7D060"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="15,2">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="15">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="&#xe805;"
                                                 FontFamily="Fontello"
                                                 Color="#F7D060"
                                                 Size="20"/>
                            </Image.Source>
                        </Image>
                        <Entry x:Name="ContactEntry"
                               Grid.Column="1"
                               Placeholder="Contact Number"
                               PlaceholderColor="#807040"
                               TextColor="White"
                               Keyboard="Telephone"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Password -->
                <Border Stroke="#F7D060"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="15,2">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="&#xe803;"
                                                 FontFamily="Fontello"
                                                 Color="#F7D060"
                                                 Size="20"/>
                            </Image.Source>
                        </Image>

                        <Entry x:Name="PasswordEntry"
                               Grid.Column="1"
                               Placeholder="Password"
                               IsPassword="True"
                               PlaceholderColor="#807040"
                               TextColor="White"
                               VerticalOptions="Center"/>

                        <Image Grid.Column="2"
                               WidthRequest="20"
                               HeightRequest="20"
                               VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="&#xe800;"
                                                 FontFamily="Fontello"
                                                 Color="#F7D060"
                                                 Size="20"/>
                            </Image.Source>
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="EyeIcon_Clicked"/>
                            </Image.GestureRecognizers>
                        </Image>
                    </Grid>
                </Border>

                <!-- Confirm Password -->
                <Border Stroke="#F7D060"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="15,2">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                        <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="&#xe803;"
                                                 FontFamily="Fontello"
                                                 Color="#F7D060"
                                                 Size="20"/>
                            </Image.Source>
                        </Image>

                        <Entry x:Name="ConfirmPasswordEntry"
                               Grid.Column="1"
                               Placeholder="Confirm Password"
                               IsPassword="True"
                               PlaceholderColor="#807040"
                               TextColor="White"
                               VerticalOptions="Center"/>

                        <Image Grid.Column="2"
                               WidthRequest="20"
                               HeightRequest="20"
                               VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource Glyph="&#xe800;"
                                                 FontFamily="Fontello"
                                                 Color="#F7D060"
                                                 Size="20"/>
                            </Image.Source>
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="ConfirmEyeIcon_Clicked"/>
                            </Image.GestureRecognizers>
                        </Image>
                    </Grid>
                </Border>

                <!-- Error -->
                <Label x:Name="ErrorLabel"
                       TextColor="#FF4444"
                       FontSize="12"
                       HorizontalTextAlignment="Center"
                       HeightRequest="20"/>

                <!-- Sign Up -->
                <Button Text="Sign Up"
                        HeightRequest="50"
                        CornerRadius="25"
                        FontAttributes="Bold"
                        TextColor="Black"
                        Clicked="SignUpButton_Clicked">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E6B325" Offset="0.1"/>
                            <GradientStop Color="#BD8C00" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <!-- Login -->
                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="3"
                                       Margin="0,3,0,0">
                    <Label Text="Already have an account?"
                           TextColor="White"/>
                    <Label Text="Login here"
                           TextColor="#F7D060"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="SignInHere_Tapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </StackLayout>
        </Frame>

    </Grid>
</ContentPage>