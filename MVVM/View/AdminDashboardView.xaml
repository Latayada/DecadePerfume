<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DecadePerfume.MVVM.View.AdminDashboardView">
    

    <!-- SIDEBAR MENU -->
    <FlyoutPage.Flyout>
        <ContentPage Title="Menu" BackgroundColor="Black">

            <StackLayout Padding="20" Spacing="15">

                <!-- LOGO -->
                <Image Source="decadelogo.png"
                       HeightRequest="120"
                       HorizontalOptions="Center"/>

                <Label Text="Admin Panel"
                       FontSize="20"
                       TextColor="#F7D060"
                       HorizontalOptions="Center"
                       FontAttributes="Bold"/>

                <!-- MENU BUTTONS -->

                <Button Text="Dashboard"
                        BackgroundColor="#F7D060"
                        TextColor="Black"
                        Clicked="Dashboard_Clicked"/>

                <Button Text="User Management"
                        BackgroundColor="#F7D060"
                        TextColor="Black"
                        Clicked="Users_Clicked"/>

                <Button Text="Product Management"
                        BackgroundColor="#F7D060"
                        TextColor="Black"
                        Clicked="Products_Clicked"/>

                <Button Text="Category Management"
                        BackgroundColor="#F7D060"
                        TextColor="Black"
                        Clicked="Category_Clicked"/>

                <Button Text="Inventory Management"
                        BackgroundColor="#F7D060"
                        TextColor="Black"
                        Clicked="Inventory_Clicked"/>

                <Button Text="POS (Point of Sale)"
                        BackgroundColor="#F7D060"
                        TextColor="Black"
                        Clicked="POS_Clicked"/>

                <!--<Button Text="Orders / Checkout"
                        BackgroundColor="#F7D060"
                        TextColor="Black"
                        Clicked="Orders_Clicked"/>-->

                <Button Text="Reports"
                        BackgroundColor="#F7D060"
                        TextColor="Black"
                        Clicked="Reports_Clicked"/>

                <!--<Button Text="User Profile"
                        BackgroundColor="#F7D060"
                        TextColor="Black"
                        Clicked="Profile_Clicked"/>-->

                <Button Text="Logout"
                        BackgroundColor="Red"
                        TextColor="White"
                        Clicked="Logout_Clicked"/>

            </StackLayout>

        </ContentPage>
    </FlyoutPage.Flyout>

    <!-- MAIN PAGE -->
    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <ContentPage Title="Dashboard" BackgroundColor="Black">
                    <ScrollView>
                        <StackLayout Padding="20" Spacing="25">

                            <!-- Welcome Message -->
                            <StackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="Decade Perfume Admin Dashboard"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#F7D060"
                                   HorizontalOptions="Center"/>
                                <Label Text="Welcome Administrator"
                                   FontSize="18"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                            </StackLayout>

                            <!-- Quick Overview Grid -->
                            <Grid ColumnSpacing="15" RowSpacing="15">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Total Users -->
                                <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="#F7D060" CornerRadius="15" Padding="20">
                                    <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="Total Users" TextColor="Black" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center"/>
                                        <Label Text="10" TextColor="Black" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                                    </StackLayout>
                                </Frame>

                                <!-- Total Products -->
                                <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="#F7D060" CornerRadius="15" Padding="20">
                                    <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="Total Products" TextColor="Black" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center"/>
                                        <Label Text="25" TextColor="Black" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                                    </StackLayout>
                                </Frame>

                                <!-- Total Sales -->
                                <Frame Grid.Row="1" Grid.Column="0" BackgroundColor="#F7D060" CornerRadius="15" Padding="20">
                                    <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="Total Sales" TextColor="Black" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center"/>
                                        <Label Text="₱5000" TextColor="Black" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                                    </StackLayout>
                                </Frame>

                                <!-- Quick Actions -->
                                <Frame Grid.Row="1" Grid.Column="1" BackgroundColor="#F7D060" CornerRadius="15" Padding="20">
                                    <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                                        <Label Text="Quick Actions" TextColor="Black" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center"/>
                                        <Button Text="Add Product" BackgroundColor="White" TextColor="Black"/>
                                        <Button Text="Add User" BackgroundColor="White" TextColor="Black"/>
                                    </StackLayout>
                                </Frame>

                            </Grid>

                        </StackLayout>
                    </ScrollView>
                </ContentPage>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>

</FlyoutPage>